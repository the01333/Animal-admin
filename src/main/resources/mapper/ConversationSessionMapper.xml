<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.puxinxiaolin.adopt.mapper.ConversationSessionMapper">

    <!-- 根据会话ID获取会话 -->
    <select id="getBySessionId" resultType="com.puxinxiaolin.adopt.entity.entity.ConversationSession">
        SELECT * FROM t_conversation_session 
        WHERE session_id = #{sessionId} AND deleted = 0
    </select>

</mapper>
