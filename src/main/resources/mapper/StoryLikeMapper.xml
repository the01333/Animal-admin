<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.puxinxiaolin.adopt.mapper.StoryLikeMapper">

    <!-- 检查用户是否点赞过故事 -->
    <select id="checkUserLiked" resultType="int">
        SELECT COUNT(*) FROM t_story_like 
        WHERE user_id = #{userId} AND story_id = #{storyId}
    </select>

    <!-- 获取故事的点赞总数 -->
    <select id="getStoryLikeCount" resultType="int">
        SELECT COUNT(*) FROM t_story_like 
        WHERE story_id = #{storyId}
    </select>

</mapper>
