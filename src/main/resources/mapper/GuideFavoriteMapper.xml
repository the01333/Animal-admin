<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.puxinxiaolin.adopt.mapper.GuideFavoriteMapper">

    <!-- 检查用户是否收藏过指南 -->
    <select id="checkUserFavorited" resultType="int">
        SELECT COUNT(*) FROM t_guide_favorite 
        WHERE user_id = #{userId} AND guide_id = #{guideId}
    </select>

    <!-- 获取指南收藏总数 -->
    <select id="getGuideFavoriteCount" resultType="int">
        SELECT COUNT(*) FROM t_guide_favorite 
        WHERE guide_id = #{guideId}
    </select>

</mapper>
